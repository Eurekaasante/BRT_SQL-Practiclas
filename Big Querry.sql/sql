--Q2. Display of ALL transactions where Total Amount is more than the average Total AMount of the entire dataset

SELECT 
    `Transaction ID`,
    `Date`,
    `Customer ID`,
    `Gender`,
    `Age`,
    `Product Category`,
    `Quantity`,
    `Price per Unit`,
    `Total Amount`
FROM `brightmotors-494417.Case_analysis.Sales`
WHERE `Total Amount` > (
    SELECT AVG(`Total Amount`) 
    FROM `brightmotors-494417.Case_analysis.Sales`
);
--350 rows of dataset were returned

