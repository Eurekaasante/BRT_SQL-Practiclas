--Q20. Display a column called Spending_Level that shows High if Total Amount is greater than 1000 or Low if not.

SELECT `Transaction id`,
        `Total Amount`,
    CASE 
        WHEN `Total Amount` > 1000 THEN 'High'
        ELSE 'Low'
        END AS Spending_Level
FROM retailanalysis.brightretail.brt_sales;

--Q21. Display a new column called Age_Group that labels customers as:
 'Youth' if Age < 30    'Adult' if Age is between 30 and 59  'Senior' if Age >= 60

 SELECT  `Customer id`,
        Age,
  CASE 
      WHEN Age < 30 THEN 'Youth'
      WHEN AGE BETWEEN 30 AND 59 THEN 'Adult'
      WHEN Age >= 60 THEN 'Senior'  

    END AS Age_Group
  FROM retailanalysis.brightretail.brt_sales;

