--Group by
----------------------------------------------
--Q15.  Find transaction per category

SELECT COUNT(*) AS Transaction_Count,
        `Product Category`
FROM retailanalysis.brightretail.brt_sales
GROUP BY `Product Category`;




--The Transaction Count for Beauty category is 307, 351 for Clothing and 342 for Elctronics 
--Q16. Find Total revenue per Gender

SELECT SUM(`Total Amount`) AS Total_Revenue,
          Gender
FROM retailanalysis.brightretail.brt_sales
GROUP BY Gender;




-- Males have spent a colletive 223 160 and females have spent 232 840

--  Q17. Find the average price per unit of each category 

SELECT AVG(`Price per Unit`) AS Average_Price,
          `Product Category`
FROM retailanalysis.brightretail.brt_sales
GROUP BY `Product Category`;




--Beauty range is averaging 184, while clothing has 174 and electronics is 181 

