--HAVING statement
---------------------------------------
--Q18.  Find the total revenue per product category where total revenue is greater than 10000

SELECT SUM (`Total Amount`) AS Total_Revenue,
          `Product Category`
FROM retailanalysis.brightretail.brt_sales
GROUP BY `Product Category`
HAVING Total_Revenue >10000;




--The Total revenue is 143 515 for Beauty products, 155 580 for Clothing and electronics with 156 905.

--Q19 Find the average quantity per product where the average is morethan 2.

SELECT AVG (Quantity) AS Average_Quantity,
            `Product Category`
FROM retailanalysis.brightretail.brt_sales
GROUP BY `Product Category`
HAVING Average_Quantity >2;




